{
  // Default: enable all rules
  "default": true,

  // Allow long lines — many files have URLs and tables that exceed 80 chars
  "MD013": false,

  // Allow duplicate headings in different sections (common in changelogs, skills)
  "MD024": {
    "siblings_only": true
  },

  // Allow inline HTML (used in badges, details/summary, etc.)
  "MD033": false
}
